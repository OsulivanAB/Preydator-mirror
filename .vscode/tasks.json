{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run build-release",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"build-release.ps1"
			],
			"isBackground": false
		},
		{
			"label": "Preydator: Commit Tasks Cleanup",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-Command",
				"git -C . add .vscode/tasks.json; git -C . commit -m cleanup_tasks_json_after_session_automation"
			],
			"isBackground": false
		}
	]
}